# Elastic Beanstalk configuration as code.
# Applies when the deploy bundle (zip containing app.jar + Procfile +
# this folder) is uploaded, which deploy.yml now builds.
#
# Points the ALB health check at the readiness group so an instance is
# only "healthy" when the app is up AND the database pool is connected.
option_settings:
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /actuator/health/readiness
    Port: '5000'
    MatcherHTTPCode: '200'
